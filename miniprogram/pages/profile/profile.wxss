.container {
  padding: 20rpx;
  min-height: 100vh;
}

.user-info {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.avatar-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90E2 0%, #5B68FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  overflow: hidden;
  border: none;
  padding: 0;
}

.avatar-btn::after {
  border: none;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

.avatar-icon {
  font-size: 64rpx;
}

.user-details {
  flex: 1;
}

.nickname-input {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 10rpx;
  width: 100%;
}

.user-id {
  font-size: 24rpx;
  color: #666666;
  display: block;
}

.stats-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #4A90E2;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
}

.function-list {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.function-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #F0F0F0;
  transition: all 0.3s ease;
}

.function-item:last-child {
  border-bottom: none;
}

.function-item:hover {
  background: #F5F7FA;
}

.function-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  width: 40rpx;
  text-align: center;
}

.function-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.function-arrow {
  font-size: 24rpx;
  color: #999999;
}

.pattern-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.pattern-content {
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 20rpx;
}

.pattern-item {
  margin-bottom: 15rpx;
  display: flex;
  flex-wrap: wrap;
}

.pattern-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #333333;
  margin-right: 10rpx;
  min-width: 120rpx;
}

.pattern-value {
  font-size: 24rpx;
  color: #666666;
  flex: 1;
  line-height: 1.5;
}

.version-info {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 20rpx;
  margin-top: 30rpx;
}