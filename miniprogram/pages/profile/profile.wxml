<view class="container">
  <!-- 用户信息 -->
  <view class="user-info">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar-image" />
      <text wx:else class="avatar-icon">👤</text>
    </button>
    <view class="user-details">
      <input 
        class="nickname-input" 
        type="nickname" 
        placeholder="点击输入昵称" 
        value="{{userInfo.nickName}}" 
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
      <text class="user-id">{{userInfo.openid ? '已登录' : '未登录'}}</text>
    </view>
    <text class="login-arrow">›</text>
  </view>
  
  <!-- 统计信息 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-value">{{userStats.streakDays || 0}}</text>
      <text class="stat-label">连续打卡</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{userStats.totalRecords || 0}}</text>
      <text class="stat-label">总记录数</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{userStats.lastRecordDate || '未记录'}}</text>
      <text class="stat-label">最后记录</text>
    </view>
  </view>
  
  <!-- 功能列表 -->
  <view class="function-list">
    <view class="function-item" bindtap="exportData">
      <text class="function-icon">📤</text>
      <text class="function-text">导出数据</text>
      <text class="function-arrow">→</text>
    </view>
    <view class="function-item" bindtap="setReminder">
      <text class="function-icon">⏰</text>
      <text class="function-text">设置提醒</text>
      <text class="function-arrow">→</text>
    </view>
    <view class="function-item" bindtap="about">
      <text class="function-icon">ℹ️</text>
      <text class="function-text">关于我们</text>
      <text class="function-arrow">→</text>
    </view>
    <view class="function-item" bindtap="feedback">
      <text class="function-icon">💬</text>
      <text class="function-text">反馈建议</text>
      <text class="function-arrow">→</text>
    </view>
  </view>
  
  <!-- 情绪模式 -->
  <view class="pattern-card">
    <text class="section-title">情绪模式</text>
    <view class="pattern-content">
      <view class="pattern-item">
        <text class="pattern-label">高频情绪：</text>
        <text class="pattern-value">{{emotionPattern.commonEmotions || '暂无数据'}}</text>
      </view>
      <view class="pattern-item">
        <text class="pattern-label">常用标签：</text>
        <text class="pattern-value">{{emotionPattern.commonTags || '暂无数据'}}</text>
      </view>
      <view class="pattern-item">
        <text class="pattern-label">有效舒缓方式：</text>
        <text class="pattern-value">{{emotionPattern.copingStrategies || '暂无数据'}}</text>
      </view>
    </view>
  </view>
  
  <!-- 版本信息 -->
  <view class="version-info">
    <text>情绪气象台 v1.0.0</text>
  </view>
</view>