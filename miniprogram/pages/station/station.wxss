.container {
  padding: 0;
  min-height: 100vh;
  background: #F5F7FA;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 30rpx 50rpx;
  border-radius: 0 0 30rpx 30rpx;
  text-align: center;
}

.page-title {
  font-size: 44rpx;
  font-weight: 600;
  color: white;
  display: block;
  margin-bottom: 15rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.overview-card {
  display: flex;
  background: white;
  margin: -30rpx 20rpx 25rpx;
  border-radius: 20rpx;
  padding: 35rpx 20rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.08);
}

.overview-item {
  flex: 1;
  text-align: center;
}

.overview-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #667eea;
  display: block;
  margin-bottom: 10rpx;
}

.overview-label {
  font-size: 24rpx;
  color: #999999;
}

.overview-divider {
  width: 2rpx;
  background: #E0E0E0;
  margin: 0 10rpx;
}

.section-header {
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999999;
  margin-top: 5rpx;
}

.chart-section {
  background: white;
  margin: 0 20rpx 25rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.emotion-bars {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.emotion-bar-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.bar-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.emotion-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.emotion-count {
  font-size: 24rpx;
  color: #999999;
}

.bar-track {
  height: 32rpx;
  background: #F0F0F0;
  border-radius: 16rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 16rpx;
  transition: width 0.5s ease;
}

.empty-chart {
  text-align: center;
  padding: 40rpx;
  color: #999999;
}

.report-section {
  background: white;
  margin: 0 20rpx 25rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.report-card {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  border-left: 8rpx solid #4CAF50;
}

.score-card {
  text-align: center;
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx dashed #A5D6A7;
}

.score-ring {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: white;
  margin: 0 auto 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.score-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #4CAF50;
}

.score-label {
  font-size: 22rpx;
  color: #666666;
}

.score-comment {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
  padding: 20rpx;
}

.comment-text {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.6;
}

.report-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.report-item {
  display: flex;
  align-items: flex-start;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 12rpx;
  padding: 20rpx;
}

.report-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}

.report-info {
  flex: 1;
}

.report-label {
  font-size: 22rpx;
  color: #666666;
  display: block;
  margin-bottom: 5rpx;
}

.report-value {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

.suggestion-item {
  background: rgba(76, 175, 80, 0.1);
}

.loading {
  text-align: center;
  padding: 60rpx;
}

.loading-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-report, .empty-stress, .empty-history {
  text-align: center;
  padding: 40rpx;
  color: #999999;
}

.empty-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 15rpx;
}

.stress-section {
  background: white;
  margin: 0 20rpx 25rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.stress-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.stress-tag {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFE0B2 0%, #FFCC80 100%);
  border-radius: 30rpx;
  padding: 15rpx 25rpx;
  min-width: 120rpx;
}

.tag-name {
  font-size: 26rpx;
  color: #E65100;
  margin-right: 10rpx;
}

.tag-count {
  font-size: 22rpx;
  color: #FF8F00;
  background: rgba(255, 255, 255, 0.8);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.history-section {
  background: white;
  margin: 0 20rpx 40rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 25rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
}

.history-weather {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
}

.weather-icon {
  font-size: 48rpx;
}

.weather-name {
  font-size: 22rpx;
  color: #999999;
  margin-top: 5rpx;
}

.history-content {
  flex: 1;
}

.history-date {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.history-diary {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.history-score {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-score .score-value {
  font-size: 28rpx;
  font-weight: 600;
  color: white;
}