/* 全局样式 */
page {
  background-color: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 通用样式 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin: 30rpx 0 20rpx 0;
}

/* 按钮样式 */
.btn {
  background-color: #4A90E2;
  color: white;
  border-radius: 8rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  margin: 20rpx 0;
}

.btn-disabled {
  background-color: #CCCCCC;
}

/* 卡片样式 */
.card {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

/* 天气图标样式 */
.weather-icon {
  width: 80rpx;
  height: 80rpx;
  margin: 10rpx;
}

/* 输入框样式 */
.input {
  border: 2rpx solid #E5E5E5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin: 10rpx 0;
  width: 100%;
  box-sizing: border-box;
}

/* 文本样式 */
.text-primary {
  color: #4A90E2;
}

.text-secondary {
  color: #666666;
  font-size: 24rpx;
}

.text-danger {
  color: #E74C3C;
}

.text-success {
  color: #27AE60;
}

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }

.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }

/* 阴影 */
.shadow {
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 圆角 */
.rounded {
  border-radius: 8rpx;
}

.rounded-lg {
  border-radius: 16rpx;
}